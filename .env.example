# === API ===
API_PORT=8080
API_ENV=development
API_LOG_LEVEL=debug

# CORS allowlist for the web origin (comma-separated for multiple).
WEB_ORIGIN=http://localhost:3000,http://localhost:3100

# Public base URL for webhooks. Sellers paste {WEBHOOK_BASE_URL}/webhooks/midtrans/{token}
# into Midtrans dashboard. In dev, expose via ngrok/cloudflared and put that URL here.
WEBHOOK_BASE_URL=http://localhost:8080

# === Auth ===
# Generate dev secret: openssl rand -hex 32
JWT_SECRET=replace-me-with-openssl-rand-hex-32
JWT_TTL_HOURS=168

# Google OAuth Client ID — get one at https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID -> "Web application"
# Authorized JavaScript origins: http://localhost:3000 (and http://localhost:3100 if used)
# The same value is shared by the API (for ID token verification) and the web (for the GIS button).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# === Database (PostgreSQL) ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sellon
POSTGRES_PASSWORD=sellon
POSTGRES_DB=sellon

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === Web ===
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
# Internal URL the Next.js server uses to reach the API (server-side fetch).
API_INTERNAL_URL=http://api:8080

# === Supabase Storage (product photos) ===
# Uploads go through the API (Go) — the service role key never reaches
# the browser. Setup:
#   1. Create a project at https://supabase.com.
#   2. Storage → New bucket → name "products" → make it PUBLIC (so the
#      generated public URL serves images directly, no token needed).
#   3. Settings → API → copy the Project URL and the service_role key.
# When all three are set, sellers can upload images from the produk-form;
# otherwise the API returns 503 and the client surfaces a friendly error.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=products

# === RajaOngkir (live ongkir) ===
# Sign up at https://rajaongkir.com to get an API key. Without these the
# /shipping/quote endpoint falls back to the built-in zone-based table.
# Tier matches your account: starter (free, JNE/TIKI/POS) | basic | pro.
RAJAONGKIR_API_KEY=
RAJAONGKIR_TIER=starter
