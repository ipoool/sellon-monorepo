# === API ===
API_PORT=8080
API_ENV=development
API_LOG_LEVEL=debug

# CORS allowlist for the web origin (comma-separated for multiple).
WEB_ORIGIN=http://localhost:3000,http://localhost:3100

# Public base URL for webhooks. Sellers paste {WEBHOOK_BASE_URL}/webhooks/midtrans/{token}
# into Midtrans dashboard. In dev, expose via ngrok/cloudflared and put that URL here.
WEBHOOK_BASE_URL=http://localhost:8080

# === Auth ===
# Generate dev secret: openssl rand -hex 32
JWT_SECRET=replace-me-with-openssl-rand-hex-32
JWT_TTL_HOURS=168

# Google OAuth Client ID — get one at https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID -> "Web application"
# Authorized JavaScript origins: http://localhost:3000 (and http://localhost:3100 if used)
# The same value is shared by the API (for ID token verification) and the web (for the GIS button).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# === Database (PostgreSQL) ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sellon
POSTGRES_PASSWORD=sellon
POSTGRES_DB=sellon

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === Web ===
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
# Internal URL the Next.js server uses to reach the API (server-side fetch).
API_INTERNAL_URL=http://api:8080

# === Supabase Storage (product photos) ===
# Uploads go through the API (Go) — the service role key never reaches
# the browser. Setup:
#   1. Create a project at https://supabase.com.
#   2. Storage → New bucket → name "stores" → make it PUBLIC (so the
#      generated public URL serves images directly, no token needed).
#   3. Settings → API → copy the Project URL dan service_role key.
#
# Folder layout di bucket (auto-created saat first upload):
#   stores/{store_id}/products/...           ← katalog produk
#   stores/{store_id}/commons/logos/...      ← logo toko
#   stores/{store_id}/commons/banners/...    ← banner storefront
#   stores/{store_id}/commons/qris/...       ← QRIS static
#   stores/{store_id}/commons/misc/...       ← upload bebas lain
#
# Kalau salah satu kosong, /uploads/image return 503 dan UI fallback ke
# URL-only input.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=stores

# === RajaOngkir (live ongkir) ===
# Sign up at https://rajaongkir.com to get an API key. Without these the
# /shipping/quote endpoint falls back to the built-in zone-based table.
# Tier matches your account: starter (free, JNE/TIKI/POS) | basic | pro.
RAJAONGKIR_API_KEY=
RAJAONGKIR_TIER=starter

# === Platform billing (SaaS subscription via Midtrans Snap) ===
# Separate Midtrans account owned by SellOn (not the seller's). When a
# seller upgrades to Pro/Bisnis they're sent to a Snap page billed
# against this account. Leave the server key empty to disable online
# checkout — the UI then only shows the "transfer manual" path.
# Webhook URL to register in this account's dashboard:
#   {WEBHOOK_BASE_URL}/webhooks/platform/midtrans
PLATFORM_MIDTRANS_SERVER_KEY=
PLATFORM_MIDTRANS_CLIENT_KEY=
PLATFORM_MIDTRANS_SANDBOX=true

# === Email (Mailtrap Send API) ===
# Sends transactional notifications to sellers (pesanan baru, pembayaran
# diterima). Uses Mailtrap's HTTPS Send API — not SMTP. Get a token from
# Mailtrap → Sending → API Tokens. Without MAILTRAP_API_KEY, email
# becomes a no-op (logs only). FROM_EMAIL must be on a verified sender
# domain in your Mailtrap account.
MAILTRAP_API_KEY=1db51ac6795d19d18f51cc66e6078b26
FROM_EMAIL=noreply@sellon.id
FROM_NAME=SellOn

# Twilio — platform-funded WhatsApp alerts to sellers when a new order
# arrives. Account SID + Auth Token from console.twilio.com. WhatsApp
# From is the sender phone in E.164 (no "whatsapp:" prefix — the code
# adds it). Sandbox sender is +14155238886 during onboarding; switch
# to your approved production number before launch. Leaving any of
# the three empty disables outbound WA — order create still succeeds,
# we just log a warning.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# === AI Content Generation (Anthropic Claude) ===
# Used by the weekly marketing tips scheduler to generate fresh email content
# every Monday. Without this key the scheduler falls back to the built-in
# static tip pool (8 rotating tips). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
