# === Production env untuk Next.js build ===
# Copy file ini ke .env.production, edit nilainya, lalu jalankan build-push.sh.
# Nilai di sini di-INLINE ke bundle saat `pnpm build` — kalau ganti
# domain / API URL, harus build + push ulang image.
#
#   cp web/.env.production.example web/.env.production
#   nano web/.env.production
#   bash scripts/build-push.sh

# Public — masuk client bundle (terlihat di browser).
# Pakai domain publik production.
NEXT_PUBLIC_API_URL=https://your-domain.id
NEXT_PUBLIC_SITE_URL=https://your-domain.id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Server-side only — dipakai Next.js server runtime untuk SSR fetch ke
# backend. Di production stack Docker Swarm, web container dan api
# container ada di overlay network yang sama (`sellon-net`), jadi
# panggil service name langsung lewat DNS internal Swarm.
#
# JANGAN pakai 127.0.0.1 — di dalam container itu artinya web itu
# sendiri (bukan host), fetch akan "connection refused".
API_INTERNAL_URL=http://api:8080
